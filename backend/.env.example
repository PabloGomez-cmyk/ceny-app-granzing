# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
TENANT_ID_DEFAULT=glazing-sa

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://centy:centy_dev@localhost:5432/centy_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth (JWT RS256) ──────────────────────────────────────────────────────────
# Dev local: generar con scripts/generate_jwt_keys.sh y dejar solo las rutas.
JWT_PRIVATE_KEY_PATH=./jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_public.pem
# Producción (Railway): no hay filesystem persistente para los .pem — pegar el
# contenido de cada clave acá (con \n en vez de saltos de línea reales si tu
# proveedor no soporta variables multilínea). Si se completan, tienen prioridad
# sobre JWT_*_KEY_PATH.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" en dev (filesystem). "r2" en producción — el filesystem de Railway
# es efímero y no sobrevive a un redeploy.
STORAGE_BACKEND=local

# Cloudflare R2 (solo si STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=centy-media
# URL pública del bucket: dominio custom conectado al bucket, o el
# subdominio r2.dev habilitado en Cloudflare Dashboard > R2 > bucket > Settings
R2_PUBLIC_BASE_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
# Crear en: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Tipo: "Web application"
# Redirect URI autorizada: http://localhost:3000/settings/gmail/callback
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GMAIL_TOKEN_ENCRYPTION_KEY=
